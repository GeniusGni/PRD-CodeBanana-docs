                    "group": "Agent Config",
                    "pages": [
                      "documentation/working-in-code-banana/basicinfo",
                      "documentation/working-in-code-banana/imsetting",
                      "documentation/working-in-code-banana/skills",
                      "documentation/working-in-code-banana/cron-job"
